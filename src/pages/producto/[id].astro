---
import MainLayout from '../../layouts/MainLayout.astro';
import productos from '../../data/productos.json';

// Le decimos a Astro que genere una página HTML por cada producto en el JSON
export function getStaticPaths() {
    return productos.map((prod) => ({
        params: { id: prod.id.toString() },
        props: { producto: prod },
    }));
}

const { producto } = Astro.props;

// Pre-armamos el mensaje de WhatsApp para el botón
const mensajeWa = `Hola Cybercadito, me interesa adquirir la licencia de *${producto.titulo}* por $${producto.precio.toFixed(2)}.`;
const urlWhatsApp = `https://wa.me/1234567890?text=${encodeURIComponent(mensajeWa)}`;
---

<MainLayout title={producto.titulo}>
    <nav class="mb-8 flex items-center text-sm text-gray-500 dark:text-gray-400 font-medium">
        <a href="/" class="hover:text-sky-500 transition">Inicio</a>
        <span class="mx-3">/</span>
        <a href={`/catalogo/${producto.categoria}`} class="hover:text-sky-500 transition capitalize">{producto.categoria}</a>
        <span class="mx-3">/</span>
        <span class="text-gray-900 dark:text-white truncate">{producto.titulo}</span>
    </nav>

    <div class="bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-2xl border border-gray-100 dark:border-slate-700">
        <div class="grid grid-cols-1 md:grid-cols-2">
            
            <div class="relative h-96 md:h-[600px] bg-gray-100 dark:bg-slate-700 group overflow-hidden">
                <img 
                    src={producto.imagen} 
                    alt={producto.titulo} 
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                />
                <div class="absolute top-6 left-6 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md px-4 py-2 rounded-full text-sm font-bold shadow-lg text-gray-900 dark:text-white">
                    {producto.icono} {producto.categoria.toUpperCase()}
                </div>
            </div>

            <div class="p-8 md:p-12 flex flex-col justify-center">
                <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 dark:text-white leading-tight mb-4">
                    {producto.titulo}
                </h1>
                <p class="text-lg text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
                    {producto.descripcion}
                </p>

                <div class="bg-sky-50 dark:bg-slate-900/50 rounded-2xl p-6 mb-8 border border-sky-100 dark:border-slate-700">
                    <h3 class="font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                        <span>✨</span> Lo que incluye tu compra:
                    </h3>
                    <ul class="space-y-3">
                        {producto.caracteristicas.map(c => (
                            <li class="flex items-center text-gray-700 dark:text-gray-300 font-medium">
                                <svg class="w-5 h-5 text-sky-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                {c}
                            </li>
                        ))}
                    </ul>
                </div>

                <div class="flex flex-col sm:flex-row items-center justify-between mt-auto pt-8 border-t border-gray-100 dark:border-slate-700 gap-6">
                    <div class="text-center sm:text-left">
                        <span class="block text-sm text-gray-500 dark:text-gray-400 font-semibold mb-1">Pago único</span>
                        <span class="text-5xl font-black text-sky-500">${producto.precio.toFixed(2)}</span>
                    </div>
                    
                    <a 
                        href={urlWhatsApp}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full sm:w-auto bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 shadow-lg shadow-green-500/30 hover:shadow-green-500/50 hover:-translate-y-1 flex items-center justify-center gap-3 text-lg"
                    >
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                        Comprar por WhatsApp
                    </a>
                </div>
            </div>
        </div>
    </div>
</MainLayout>