---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductTabs from '../../components/react/ProductTabs.jsx';
import AddToCartBtn from '../../components/react/AddToCartBtn.jsx'; // Importamos el botón del carrito
import productos from '../../data/productos.json';

export function getStaticPaths() {
    return productos.map((prod) => ({
        params: { id: prod.id.toString() },
        props: { producto: prod },
    }));
}

const { producto } = Astro.props;

// Precio simulado "antes" para generar urgencia (como lo hace Gamers Outlet)
const precioOriginal = (producto.precio * 1.45).toFixed(2);
---

<MainLayout title={producto.titulo}>
    <nav class="mb-6 flex items-center text-sm text-gray-500 dark:text-gray-400 font-medium">
        <a href="/" class="hover:text-sky-500 transition">Inicio</a>
        <span class="mx-3">/</span>
        <a href={`/catalogo/${producto.categoria}`} class="hover:text-sky-500 transition capitalize">{producto.categoria}</a>
        <span class="mx-3">/</span>
        <span class="text-gray-900 dark:text-white truncate">{producto.titulo}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <div class="lg:col-span-7 space-y-6">
            <div class="bg-white dark:bg-slate-800 rounded-2xl p-4 shadow-sm border border-gray-100 dark:border-slate-700">
                <div class="relative h-64 sm:h-96 w-full rounded-xl overflow-hidden bg-gray-100 dark:bg-slate-900">
                    <img src={producto.imagen} alt={producto.titulo} class="w-full h-full object-cover" />
                </div>
            </div>

            <div class="flex flex-wrap gap-3">
                <div class="flex items-center gap-2 bg-gray-100 dark:bg-slate-800 px-4 py-2 rounded-lg text-sm font-bold text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-slate-700">
                    🌍 Región: <span class="text-sky-500">Global</span>
                </div>
                <div class="flex items-center gap-2 bg-gray-100 dark:bg-slate-800 px-4 py-2 rounded-lg text-sm font-bold text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-slate-700">
                    {producto.icono} Plataforma: <span class="text-sky-500 capitalize">{producto.categoria}</span>
                </div>
                <div class="flex items-center gap-2 bg-gray-100 dark:bg-slate-800 px-4 py-2 rounded-lg text-sm font-bold text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-slate-700">
                    ⚡ Entrega: <span class="text-green-500">Inmediata</span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-5 bg-white dark:bg-slate-800 rounded-2xl p-6 sm:p-8 shadow-2xl border border-gray-100 dark:border-slate-700 sticky top-24">
            <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white leading-tight mb-2">
                {producto.titulo}
            </h1>
            
            <div class="flex items-center gap-2 mb-6">
                <span class="flex text-yellow-400 text-sm">★★★★★</span>
                <span class="text-xs text-gray-500 dark:text-gray-400 font-medium">(Producto verificado)</span>
            </div>

            <div class="bg-gray-50 dark:bg-slate-900/50 p-6 rounded-xl border border-gray-100 dark:border-slate-700 mb-6">
                <div class="flex items-end gap-3 mb-1">
                    <span class="text-5xl font-black text-gray-900 dark:text-white">${producto.precio.toFixed(2)}</span>
                    <span class="text-xl text-gray-400 line-through font-bold pb-1">${precioOriginal}</span>
                </div>
                <p class="text-sm text-green-600 dark:text-green-400 font-bold mt-2">
                    Ahorras un 45% respecto al precio oficial
                </p>
            </div>

            <AddToCartBtn client:load producto={producto} />

            <div class="grid grid-cols-2 gap-4 text-center border-t border-gray-100 dark:border-slate-700 pt-6">
                <div>
                    <span class="block text-xl mb-1">🛡️</span>
                    <span class="text-xs font-bold text-gray-500 dark:text-gray-400">Pago 100% Seguro</span>
                </div>
                <div>
                    <span class="block text-xl mb-1">🔑</span>
                    <span class="text-xs font-bold text-gray-500 dark:text-gray-400">Clave Original</span>
                </div>
            </div>
        </div>
    </div>

    <ProductTabs 
        client:visible 
        descripcion={producto.descripcion} 
        caracteristicas={producto.caracteristicas} 
    />
    
</MainLayout>