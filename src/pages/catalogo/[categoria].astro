---
import MainLayout from '../../layouts/MainLayout.astro';
import productos from '../../data/productos.json';

// Astro necesita saber qué URLs son válidas para esta ruta dinámica
export function getStaticPaths() {
  const categorias = ['windows', 'xbox', 'office', 'todos'];
  
  return categorias.map((cat) => {
    // Filtramos los productos según la categoría de la URL
    const filtrados = cat === 'todos' 
      ? productos 
      : productos.filter(p => p.categoria === cat);
      
    return {
      params: { categoria: cat },
      props: { productos: filtrados }, // Pasamos los productos a la página
    };
  });
}

const { categoria } = Astro.params;
const { productos } = Astro.props;

// Un diccionario rápido para los títulos bonitos
const titulos = {
    'windows': 'Ecosistema Windows 💻',
    'xbox': 'Zona Xbox Gaming 🎮',
    'office': 'Herramientas Office 📄',
    'todos': 'Catálogo Completo 🌟'
};
---

<MainLayout title={titulos[categoria]}>
    <header class="mb-10 pb-6 border-b border-gray-200 dark:border-slate-800 flex justify-between items-end">
        <div>
            <a href="/" class="text-sm text-gray-500 hover:text-sky-500 mb-2 inline-block transition">← Volver al Inicio</a>
            <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white capitalize">{titulos[categoria]}</h1>
        </div>
        <span class="text-gray-500 font-medium bg-gray-200 dark:bg-slate-800 px-3 py-1 rounded-full text-sm">
            {productos.length} productos
        </span>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {productos.map((prod) => (
            <article class="bg-white dark:bg-slate-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl border border-gray-100 dark:border-slate-700 transition-all duration-300 flex flex-col group transform hover:-translate-y-1">
                
                <div class="h-48 relative overflow-hidden">
                    <img src={prod.imagen} alt={prod.titulo} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-in-out" />
                    <div class="absolute top-3 right-3 bg-white/90 dark:bg-slate-900/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 dark:text-gray-200 shadow-sm">
                        {prod.icono} {prod.categoria.toUpperCase()}
                    </div>
                </div>
                
                <div class="p-5 flex-grow flex flex-col justify-between">
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white leading-tight">{prod.titulo}</h3>
                    </div>
                    
                    <div class="mt-4 flex items-center justify-between border-t border-gray-100 dark:border-slate-700 pt-4">
                        <span class="text-2xl font-black text-sky-500">${prod.precio.toFixed(2)}</span>
                        
                        <button class="text-sm font-semibold text-gray-400 group-hover:text-sky-500 transition-colors">
                            Ver Detalles ➔
                        </button>
                    </div>
                </div>
            </article>
        ))}
    </div>
</MainLayout>